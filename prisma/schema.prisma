generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPTABILITE
  VENDEUR
  CHARGE_PROJET
}

enum TypeContrat {
  PRELIMINAIRE
  ENTREPRISE
}

enum TypeProjet {
  JUMELE
  MAISON
  MULTILOGEMENT
}

enum PhaseProjet {
  SIGNE
  PREPARATION
  CHANTIER
  LIVRAISON
  TERMINE
}

enum StatutTache {
  NON_COMMENCE
  CONFIRME
  EN_COURS
  COMPLETE
  DECALE
}

enum StatutExtra {
  EN_ATTENTE
  SIGNE
  REFUSE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nom       String
  prenom    String
  role      Role
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projetsVendeur Projet[] @relation("Vendeur")
  projetsCharge  Projet[] @relation("ChargeProjet")
}

model Client {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String
  telephone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projets Projet[]
}

model Projet {
  id              String      @id @default(uuid())
  numero          String      @unique
  adresse         String
  ville           String
  typeProjet      TypeProjet
  typeContrat     TypeContrat
  phase           PhaseProjet @default(SIGNE)
  dateContrat     DateTime?
  dateLivraison   DateTime?
  montantTotal    Decimal?    @db.Decimal(12, 2)
  toleranceJours  Int         @default(3)
  slug            String?     @unique
  urlClient       String?     @unique
  clientId        String
  vendeurId       String?
  chargeProjetId  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  client      Client  @relation(fields: [clientId], references: [id])
  vendeur     User?   @relation("Vendeur", fields: [vendeurId], references: [id])
  chargeProjet User?  @relation("ChargeProjet", fields: [chargeProjetId], references: [id])

  taches      Tache[]
  extras      Extra[]
  paiements   Paiement[]
  fournisseurs ProjetFournisseur[]
}

model Tache {
  id            String      @id @default(uuid())
  projetId      String
  nom           String
  description   String?
  ordre         Int
  dateDebut     DateTime?
  dateFin       DateTime?
  dureeJours    Int         @default(1)
  statut        StatutTache @default(NON_COMMENCE)
  visibleClient Boolean     @default(false)
  interne       Boolean     @default(false)
  assigneA      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Extra {
  id          String      @id @default(uuid())
  projetId    String
  description String
  montant     Float
  fournisseur String?
  statut      StatutExtra @default(EN_ATTENTE)
  signeLe     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Paiement {
  id          String   @id @default(uuid())
  projetId    String
  description String
  montant     Float
  pourcentage Float?
  recu        Boolean  @default(false)
  datePrevu   DateTime?
  dateRecu    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Fournisseur {
  id        String   @id @default(uuid())
  nom       String
  email     String?
  telephone String?
  metier    String?
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  projets ProjetFournisseur[]
}

model ProjetFournisseur {
  id           String  @id @default(uuid())
  projetId     String
  fournisseurId String
  budgetAlloue Float?
  confirme     Boolean @default(false)

  projet      Projet      @relation(fields: [projetId], references: [id], onDelete: Cascade)
  fournisseur Fournisseur @relation(fields: [fournisseurId], references: [id])
}
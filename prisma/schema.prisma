generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPTABILITE
  VENDEUR
  CHARGE_PROJET
  DEVELOPPEUR
}

enum TypeContrat {
  PRELIMINAIRE
  ENTREPRISE
}

enum TypeProjet {
  JUMELE
  MAISON
  MULTILOGEMENT
}

enum PhaseProjet {
  SIGNE
  PREPARATION
  CHANTIER
  LIVRAISON
  TERMINE
}

enum StatutTache {
  NON_COMMENCE
  CONFIRME
  EN_COURS
  COMPLETE
  DECALE
}

enum StatutExtra {
  EN_ATTENTE
  SIGNE
  REFUSE
}

enum CategorieDepense {
  MATERIAUX
  SOUS_TRAITANT
  MAIN_OEUVRE
  EQUIPEMENT
  AUTRE
}

// Marqueur d'ancrage d'inspection GCR posé sur UNE étape de cédule (Tache). Une
// inspection dérive sa date de l'étape portant le marqueur de son type. Au plus
// un marqueur par (projet, type) — déplacer le marqueur efface l'ancien.
enum AncrageInspection {
  GYPSE
  FINITION
}

enum TypeInspectionGCR {
  GYPSE
  FINITION
  AUTRE
}

enum StatutInspectionGCR {
  A_RESERVER
  RESERVE
  COMPLETEE
  NON_CONFORME
}

// Listes simples de l'onglet Listes (Permis / Arpentage / Autres). Statut
// générique partagé par les trois catégories (raffinable par catégorie plus tard).
enum CategorieListe {
  PERMIS
  ARPENTAGE
  AUTRE
}

enum StatutListe {
  A_FAIRE
  EN_COURS
  COMPLETE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  nom           String
  prenom        String
  role          Role
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projetsVendeur Projet[] @relation("Vendeur")
  projetsCharge  Projet[] @relation("ChargeProjet")
  notes          Note[]
}

model Client {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String
  telephone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projets Projet[]
}

model Projet {
  id              String      @id @default(uuid())
  numero          String      @unique
  adresse         String
  ville           String
  typeProjet      TypeProjet
  typeContrat     TypeContrat
  phase           PhaseProjet @default(SIGNE)
  dateContrat     DateTime?
  dateLivraison   DateTime?
  montantTotal    Decimal?    @db.Decimal(12, 2)
  toleranceJours  Int         @default(3)
  slug            String?     @unique
  urlClient       String?
  latitude        Float?
  longitude       Float?
  clientId        String
  vendeurId       String?
  chargeProjetId  String?
  // Souvenir du template appliqué (création + changement de template) → permet à
  // « Réinitialiser » de revenir fidèlement à CE template. Nullable, SetNull si
  // le template est supprimé → fallback gracieux sur le défaut par type.
  templateId      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  client      Client  @relation(fields: [clientId], references: [id])
  vendeur     User?   @relation("Vendeur", fields: [vendeurId], references: [id])
  chargeProjet User?  @relation("ChargeProjet", fields: [chargeProjetId], references: [id])
  template    Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  taches         Tache[]
  extras         Extra[]
  paiements      Paiement[]
  fournisseurs   ProjetFournisseur[]
  feuillesTemps  FeuilleTemps[]
  depenses       Depense[]
  inspectionsGCR InspectionGCR[]
  listeItems     ListeItem[]
  notes          Note[]
}

model Tache {
  id            String      @id @default(uuid())
  projetId      String
  nom           String
  description   String?
  ordre         Int
  dateDebut     DateTime?
  dateFin       DateTime?
  dureeJours    Int         @default(1)
  statut        StatutTache @default(NON_COMMENCE)
  visibleClient Boolean     @default(false)
  interne       Boolean     @default(false)
  assigneA      String?
  buffer        Int         @default(0)
  // Lien « même jour » (bloc parent/enfant) PER-PROJET : les tâches partageant
  // le même groupeId forment un bloc débutant le même jour. Un groupe a >= 2
  // membres ; s'il retombe à 1, son groupeId est vidé. Voir cedula-utils.ts
  // (construireBlocs / validerGroupes) pour la cascade et l'exemption de conflit.
  groupeId      String?
  // Marqueur d'ancrage d'inspection GCR (GYPSE / FINITION). L'inspection du même
  // type dérive sa date de cette étape (dateDebut). Au plus un par projet+type.
  // Préservé au travers du delete+recreate de la cédule (cf. groupeId).
  ancrageInspection AncrageInspection?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Extra {
  id          String      @id @default(uuid())
  projetId    String
  description String
  montant     Float
  fournisseur String?
  statut      StatutExtra @default(EN_ATTENTE)
  signeLe     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Paiement {
  id          String   @id @default(uuid())
  projetId    String
  description String
  montant     Float
  pourcentage Float?
  recu        Boolean  @default(false)
  datePrevu   DateTime?
  dateRecu    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)
}

model Fournisseur {
  id        String   @id @default(uuid())
  nom       String
  email     String?
  telephone String?
  metier    String?
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  projets ProjetFournisseur[]
}

model ProjetFournisseur {
  id           String  @id @default(uuid())
  projetId     String
  fournisseurId String
  budgetAlloue Float?
  confirme     Boolean @default(false)

  projet      Projet      @relation(fields: [projetId], references: [id], onDelete: Cascade)
  fournisseur Fournisseur @relation(fields: [fournisseurId], references: [id])
}

model Template {
  id        String   @id @default(uuid())
  nom       String
  type      TypeProjet
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etapes  TemplateEtape[]
  projets Projet[]
}

model TemplateEtape {
  id            String  @id @default(uuid())
  templateId    String
  nom           String
  ordre         Int
  joursDefaut   Int
  assigneA      String?
  visibleClient Boolean @default(true)
  interne       Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, ordre])
}

model Parametres {
  id                      String   @id @default("singleton")
  nomCompagnie            String   @default("Habitations DG")
  rbq                     String   @default("5856-1036-01")
  email                   String   @default("info@habitations-dg.com")
  telephone               String   @default("")
  siteWeb                 String   @default("habitations-dg.com")
  maxHeuresParSemaine     Float    @default(36.5)
  margeCeduleJours        Int      @default(5)
  toleranceDefautJours    Int      @default(3)
  updatedAt               DateTime @updatedAt
}

// Périodes non ouvrables GLOBALES (vacances de la construction ~2 sem., fériés
// 1 jour, shutdowns custom). Le moteur de cédule saute ces dates comme les
// week-ends. Voir lib/cedula-utils.ts (construireEstOuvrable).
model PeriodeNonOuvrable {
  id        String   @id @default(uuid())
  nom       String
  dateDebut DateTime
  dateFin   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employe {
  id            String   @id @default(uuid())
  prenom        String
  nom           String
  email         String?
  telephone     String?
  tauxHoraire   Float    @default(0)
  metier        String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  feuillesTemps FeuilleTemps[]
}

model FeuilleTemps {
  id          String   @id @default(uuid())
  projetId    String
  employeId   String
  date        DateTime
  heures      Float
  tauxHoraire Float
  notes       String?
  approuve    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projet  Projet  @relation(fields: [projetId], references: [id], onDelete: Cascade)
  employe Employe @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@index([projetId])
  @@index([employeId])
}

model Depense {
  id          String           @id @default(uuid())
  projetId    String
  categorie   CategorieDepense
  description String
  fournisseur String?
  montant     Float
  dateDepense DateTime
  facture     String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)

  @@index([projetId])
}

// Inspection GCR (garantie). Une par type GYPSE/FINITION auto-créée par projet ;
// AUTRE = manuel. La date est DÉRIVÉE (non stockée) de l'étape de cédule portant
// le marqueur Tache.ancrageInspection du même type. dateReservee renseignée
// ⇒ statut RESERVE. Voir lib/inspection-gcr.ts.
model InspectionGCR {
  id           String              @id @default(uuid())
  projetId     String
  type         TypeInspectionGCR
  statut       StatutInspectionGCR @default(A_RESERVER)
  dateReservee DateTime?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)

  @@index([projetId])
}

// Item de liste simple (Permis / Arpentage / Autres) de l'onglet Listes (Lot 2).
// Indépendant des inspections GCR. Statut générique A_FAIRE/EN_COURS/COMPLETE.
model ListeItem {
  id        String         @id @default(uuid())
  projetId  String
  categorie CategorieListe
  nom       String
  statut    StatutListe    @default(A_FAIRE)
  date      DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  projet Projet @relation(fields: [projetId], references: [id], onDelete: Cascade)

  @@index([projetId])
}

// Note / to-do PRIVÉE par utilisateur (panneau dashboard). userId = propriétaire ;
// chaque user ne voit/édite QUE ses notes (filtré dans les routes). Tag projet
// OPTIONNEL (projetId nullable, SetNull si le projet est supprimé → la note
// devient libre). « fait » = case to-do cochable.
model Note {
  id        String   @id @default(uuid())
  userId    String
  contenu   String
  fait      Boolean  @default(false)
  projetId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projet Projet? @relation(fields: [projetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projetId])
}

// Permissions configurables (grain grossier) par rôle.
// Une ligne par rôle CONFIGURABLE (COMPTABILITE, VENDEUR, CHARGE_PROJET).
// ADMIN et DEVELOPPEUR ne sont jamais dans cette table : accès total en dur
// dans auth-guard.ts (ne peuvent pas être enfermés dehors par une config).
model RolePermission {
  role         Role     @id
  voirCosting  Boolean  @default(false)
  voirFeuilles Boolean  @default(false)
  editFeuilles Boolean  @default(false)
  voirGCR      Boolean  @default(false)
  editCedule   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}
